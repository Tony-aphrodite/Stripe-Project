document.addEventListener("DOMContentLoaded",function(){const e=document.querySelector(".hamburger"),t=document.getElementById("toggle-main-menu-mobile"),n=document.getElementById("hamburgerMenu");e.addEventListener("click",function(){e.classList.toggle("is-active");const s=t.getAttribute("aria-expanded")==="true";t.setAttribute("aria-expanded",!s),n.classList.toggle("hidden",s)})})
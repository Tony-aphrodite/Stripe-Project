# Voltika Configurador - Environment Variables
# Copy this file to .env and fill in your actual keys

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Database
DB_HOST=localhost
DB_NAME=voltika_
DB_USER=voltika
DB_PASS=your_db_password

# SMTP (Email)
SMTP_HOST=smtp.ionos.mx
SMTP_PORT=465
SMTP_USER=voltika@riactor.com
SMTP_PASS=your_smtp_password

# SMSMasivos (OTP)
SMSMASIVOS_API_KEY=your_smsmasivos_api_key

# Truora (Identity Verification)
TRUORA_API_KEY=your_truora_api_key
# Webhook shared secret — configured in the Truora dashboard when subscribing
# to the document-validation / face-recognition webhook events.
TRUORA_WEBHOOK_SECRET=your_truora_webhook_secret
# Feature flags (set to 1 after customer confirms production credentials)
TRUORA_DOC_VALIDATION_ENABLED=0
TRUORA_FACE_MATCH_ENABLED=1

# Circulo de Credito (Credit Bureau)
CDC_API_KEY=your_cdc_api_key
